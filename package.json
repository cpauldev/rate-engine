{
  "name": "rate-engine",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Christian Paul (https://github.com/cpauldev)",
  "description": "RateEngine is a client-agnostic, multi-stage rate limiting engine for TypeScript, powered by `@upstash/ratelimit`. Designed for tiered pipelines (Global to Endpoint-level) with fail-open/fail-closed safety, supporting any Redis-compatible backend.",
  "keywords": [
    "ratelimit",
    "rate-limiter",
    "rate-limiting",
    "throttling",
    "upstash",
    "upstash-ratelimit",
    "redis",
    "typescript",
    "nodejs",
    "serverless",
    "edge",
    "sliding-window",
    "token-bucket",
    "fail-open",
    "fail-closed",
    "tiered-pipelines",
    "api-protection",
    "api-security",
    "ddos-protection"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cpauldev/rate-engine.git"
  },
  "bugs": {
    "url": "https://github.com/cpauldev/rate-engine/issues"
  },
  "homepage": "https://github.com/cpauldev/rate-engine#readme",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8"
  },
  "peerDependencies": {
    "@upstash/redis": "^1.34.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "private": false
}
